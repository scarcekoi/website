---
import { flavors } from "@catppuccin/palette";

import { githubUrl } from "@data/links";

import Default from "@layouts/Default.astro";

import PageIntro from "@components/PageIntro.astro";
import ColorRow from "./_components/ColorRow.svelte";

const flavorNames = ["latte", "frappe", "macchiato", "mocha"] as const;

// Get all color names from the first flavor (they're the same across all flavors)
const colorNames = Object.keys(flavors.mocha.colors);

// Group colors by category for better organization
const colorGroups = {
  "Base Colors": [
    "rosewater",
    "flamingo",
    "pink",
    "mauve",
    "red",
    "maroon",
    "peach",
    "yellow",
    "green",
    "teal",
    "sky",
    "sapphire",
    "blue",
    "lavender",
  ],
  "Text & Surface": [
    "text",
    "subtext1",
    "subtext0",
    "overlay2",
    "overlay1",
    "overlay0",
    "surface2",
    "surface1",
    "surface0",
    "base",
    "mantle",
    "crust",
  ],
};
---

<Default
  title="Palette • Catppuccin"
  description="Dive into Catppuccin's palette: four unique pastel color palettes named 'flavors'. Ideal for your next project!">
  <PageIntro title="Palette">
    <p class="intro-text">
      Catppuccin consists of 4 beautiful pastel color palettes, named <strong>flavors</strong>. Hover over any color to
      copy its hex value.
    </p>
    <p class="intro-subtext">
      If you'd like to use them for your own project, refer to our
      <a href=`${githubUrl}/catppuccin/blob/main/docs/style-guide.md`>style guide</a>
      for general use cases and guidelines.
    </p>

    <p class="flavor-stats">4 flavors & {colorNames.length} colours</p>

    {
      Object.entries(colorGroups).map(([groupName, colors]) => (
        <section class="color-section">
          <h2 class="section-title">{groupName}</h2>
          <div class="color-table">
            <div class="table-header">
              <div class="header-color">Color</div>
              {flavorNames.map((name) => (
                <div class="header-flavor">{name}</div>
              ))}
            </div>
            {colors.map((colorName) => (
              <ColorRow
                client:load
                colorName={colorName}
                flavors={{
                  latte: flavors.latte.colors[colorName as keyof typeof flavors.latte.colors].hex,
                  frappe: flavors.frappe.colors[colorName as keyof typeof flavors.frappe.colors].hex,
                  macchiato: flavors.macchiato.colors[colorName as keyof typeof flavors.macchiato.colors].hex,
                  mocha: flavors.mocha.colors[colorName as keyof typeof flavors.mocha.colors].hex,
                }}
              />
            ))}
          </div>
        </section>
      ))
    }
  </PageIntro>

  <style lang="scss">
    @use "@styles/utils";

    :root {
      --accent-color: var(--mauve);
    }

    .intro-text {
      font-size: 1.8rem;
      color: var(--text);
      margin-block-end: var(--space-xs);
    }

    .intro-subtext {
      font-size: 1.6rem;
      color: var(--subtext0);
      margin-block-end: var(--space-md);
    }

    .flavor-stats {
      font-family: monospace;
      font-size: 1.4rem;
      color: var(--subtext0);
      margin-block-end: var(--space-lg);
    }

    .color-section {
      margin-block-end: var(--space-xl);
    }

    .section-title {
      font-size: 2rem;
      font-weight: 600;
      color: var(--text);
      margin-block-end: var(--space-md);
      padding-block-end: var(--space-xs);
      border-bottom: 1px solid var(--surface0);
    }

    .color-table {
      display: flex;
      flex-direction: column;
      gap: 0;
      background: var(--mantle);
      border-radius: var(--border-radius-normal);
      overflow: hidden;
    }

    .table-header {
      display: grid;
      grid-template-columns: 1fr repeat(4, 1fr);
      gap: var(--space-xs);
      padding: var(--space-sm) var(--space-md);
      background: var(--surface0);
      font-family: monospace;
      font-size: 1.4rem;
      color: var(--subtext0);
      text-transform: capitalize;
    }

    .header-color {
      font-weight: 600;
    }

    .header-flavor {
      text-align: center;
    }

    @media (max-width: 768px) {
      .table-header {
        grid-template-columns: 1fr repeat(4, minmax(60px, 1fr));
        padding: var(--space-xs) var(--space-sm);
        font-size: 1.2rem;
      }

      .header-flavor {
        font-size: 1.1rem;
      }
    }

    @media (max-width: 480px) {
      .table-header {
        display: none;
      }
    }
  </style>
</Default>
